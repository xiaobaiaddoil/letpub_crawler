# ==========================================
# LetPub爬虫系统配置文件
# ==========================================

# 应用配置
DEBUG=false                    # 是否开启调试模式（会输出DEBUG级别日志）
CONSOLE_LOG_LEVEL=WARNING      # 控制台日志级别 (DEBUG/INFO/WARNING/ERROR)
# ==========================================
# 部署示例
# ==========================================

# 主服务器 (.env)
# ----------------
# RUN_MODE=master
# DATABASE_URL=postgresql://user:pass@db-host:5432/letpub_crawler
# PORT=8000

# Worker节点 (.env)
# ----------------
# DATABASE_URL=postgresql://user:pass@db-host:5432/letpub_crawler
# WORKER_ID=worker-01
# HEARTBEAT_INTERVAL=30
# 运行模式 (master/worker/standalone)
# master: 主服务器模式 - 只提供管理界面和API，不运行爬虫
# worker: Worker模式 - 请使用 worker.py 脚本运行
# standalone: 单机模式 - 管理界面 + 本地爬虫（默认）
RUN_MODE=worker

HOST=xxx
PORT=xx
DB_PORT=xx
DB_NAME=xxx

# Master服务器URL（Worker使用，用于获取Cookie池中的随机Cookie）
# 示例: MASTER_URL=http://192.168.0.100:8000
MASTER_URL=http://${HOST}:${PORT}
# 运行模式 (master/worker/standalone)
# master: 主服务器模式 - 只提供管理界面和API，不运行爬虫
# worker: Worker模式 - 请使用 worker.py 脚本运行
# standalone: 单机模式 - 管理界面 + 本地爬虫（默认）
RUN_MODE=worker

# 数据库配置 (所有节点连接同一个数据库)
DATABASE_URL=postgresql://xx:xx@${HOST}:${DB_PORT}/${DB_NAME}

# 爬虫配置
CRAWL_DELAY_MIN=10              # 请求最小延迟（秒）
CRAWL_DELAY_MAX=20              # 请求最大延迟（秒）
MAX_RETRY=3                    # 任务最大重试次数
BATCH_SIZE=5                   # 每次获取任务数量

# 分布式配置
# Worker标识，为空则自动生成（格式：hostname-pid-uuid）
WORKER_ID=
# 任务锁定超时时间（秒），超时后任务会被释放给其他worker
TASK_LOCK_TIMEOUT=300
# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30
# Worker超时时间（秒），超过此时间无心跳视为离线
WORKER_TIMEOUT=120
# 是否自动启动爬虫服务（仅standalone模式有效）
CRAWLER_AUTO_START=true

# Cookie配置 (登录后从浏览器复制)
LETPUB_COOKIE=

# 加密密钥（用于加密存储账号密码）
# 生产环境必须设置！可以使用以下命令生成：
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=286Ks1alC1Wa-a9pueWn9iamI2AaNRDydHYqmwDEl0g=

