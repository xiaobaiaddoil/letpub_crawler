# ==========================================
# LetPub爬虫系统配置文件
# ==========================================

# 应用配置
DEBUG=false                    # 是否开启调试模式（会输出DEBUG级别日志）
CONSOLE_LOG_LEVEL=WARNING      # 控制台日志级别 (DEBUG/INFO/WARNING/ERROR)
TZ=Asia/Shanghai               # 容器时区
LOG_TIMEZONE=Asia/Shanghai     # 日志文件名和日志时间使用的时区
APP_LOG_DIR=/app/logs/app      # Web/API 容器日志目录（宿主机 ./logs/app）
WORKER_LOG_DIR=/app/logs/worker  # Worker 容器日志目录（宿主机 ./logs/worker）

# 主节点本机 worker 默认使用 host 网络，便于访问宿主机 127.0.0.1 上的 Clash/本地代理。
# 如需覆盖本机 worker 连接地址，可设置以下两项。
WORKER_DATABASE_URL=
WORKER_MASTER_URL=
# 非 host 网络 worker 访问宿主机本地代理时可设置，例如 host.docker.internal。
HOST_PROXY_HOST=
# ==========================================
# 部署示例
# ==========================================

# 主服务器 (.env)
# ----------------
# RUN_MODE=master
# DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>
# PORT=8000

# Worker节点 (.env)
# ----------------
# DATABASE_URL=postgresql://<db-user>:<db-password>@<db-host>:5432/<db-name>
# WORKER_ID=worker-01
# HEARTBEAT_INTERVAL=30
# 运行模式 (master/worker/standalone)
# master: 主服务器模式 - 只提供管理界面和API，不运行爬虫
# worker: Worker模式 - 请使用 worker.py 脚本运行
# standalone: 单机模式 - 管理界面 + 本地爬虫（默认）
RUN_MODE=worker

HOST=xxx
PORT=xx
DB_PORT=xx
DB_NAME=xxx
DB_USER=
DB_PASSWORD=

# Master服务器URL（Worker使用，用于获取Cookie池中的随机Cookie）
# 示例: MASTER_URL=http://192.168.0.100:8000
MASTER_URL=http://${HOST}:${PORT}
# 运行模式 (master/worker/standalone)
# master: 主服务器模式 - 只提供管理界面和API，不运行爬虫
# worker: Worker模式 - 请使用 worker.py 脚本运行
# standalone: 单机模式 - 管理界面 + 本地爬虫（默认）
RUN_MODE=worker

# 数据库配置 (所有节点连接同一个数据库)
DATABASE_URL=

# 爬虫配置
CRAWLER_FETCH_MODE=http        # http: 默认纯HTTP/API；browser: 临时回退Playwright浏览器
CRAWLER_ALLOW_DIRECT_FALLBACK=false # 代理不可用时是否允许直连；生产建议 false，避免出口 IP 被限流
PROXY_UNAVAILABLE_SLEEP_SECONDS=60  # 代理池无可用代理时，worker 释放任务并休眠的秒数
CRAWL_DELAY_MIN=1               # HTTP 页面请求最小延迟（秒）
CRAWL_DELAY_MAX=3               # HTTP 页面请求最大延迟（秒）
MAX_RETRY=3                    # 任务最大重试次数
BATCH_SIZE=5                   # 每次获取任务数量
PARALLEL_WORKERS=4             # 每个 worker 同时执行的任务数
COMMENT_PARALLEL_WORKERS=1     # 评论任务专用并发数
COMMENT_DELAY_MIN=0.5          # 评论 API 每页请求最小延迟（秒）
COMMENT_DELAY_MAX=1.5          # 评论 API 每页请求最大延迟（秒）

# Docker worker 构建目标
# worker-http: 默认，不安装浏览器，适配 CRAWLER_FETCH_MODE=http
# worker-slim: 安装 chromium-headless-shell，适配 CRAWLER_FETCH_MODE=browser
WORKER_BUILD_TARGET=worker-http

# 分布式配置
# Worker标识，为空则自动生成（格式：hostname-pid-uuid）
WORKER_ID=
# 任务锁定超时时间（秒），超时后任务会被释放给其他worker
TASK_LOCK_TIMEOUT=300
# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30
# Worker超时时间（秒），超过此时间无心跳视为离线
WORKER_TIMEOUT=120
# 是否自动启动爬虫服务（仅standalone模式有效）
CRAWLER_AUTO_START=true

# Cookie配置 (登录后从浏览器复制)
LETPUB_COOKIE=

# 加密密钥（用于加密存储账号密码）
# 生产环境必须设置！可以使用以下命令生成：
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
