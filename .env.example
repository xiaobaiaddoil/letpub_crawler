# 应用配置
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql://postgre:123456@192.168.0.110:5432/letpub_crawler

# 爬虫配置
CRAWL_DELAY_MIN=3
CRAWL_DELAY_MAX=8
MAX_RETRY=3

# 分布式配置
# Worker标识，为空则自动生成（格式：hostname-pid-uuid）
WORKER_ID=              
# 任务锁定超时时间（秒），超时后任务会被释放给其他worker
TASK_LOCK_TIMEOUT=300
# 是否自动启动爬虫服务  
CRAWLER_AUTO_START=true

# Cookie配置 (登录后从浏览器复制)
LETPUB_COOKIE=

# 服务器配置
HOST=0.0.0.0
PORT=8000
