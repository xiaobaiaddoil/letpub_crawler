# Copy values from here into the project .env when running Docker Compose.
# docker compose reads .env from the repository root by default.

APP_PORT=8000
LETPUB_WEB_IMAGE=letpub-crawler:web
LETPUB_WORKER_IMAGE=letpub-crawler:worker
PYTHON_BASE_IMAGE=public.ecr.aws/docker/library/python:3.12-slim
PLAYWRIGHT_BASE_IMAGE=mcr.microsoft.com/playwright/python:v1.57.0-noble
UV_VERSION=0.11.15

POSTGRES_PORT=15432
POSTGRES_DB=letpub_crawler2
POSTGRES_USER=letpub
POSTGRES_PASSWORD=change_me
POSTGRES_DATA_DIR=/home/cc/database/letpub_crawler/postgres

# master publishes tasks and serves the Web UI. Workers execute tasks.
RUN_MODE=master
CRAWLER_AUTO_START=false
PARALLEL_WORKERS=3
CRAWLER_WORKER_ID=
# Leave LOCAL_WORKER_ID empty when scaling local workers; each worker will generate a unique ID.
LOCAL_WORKER_ID=
LOCAL_WORKER_CONCURRENCY=2
CONSOLE_LOG_LEVEL=INFO

# Required in production for encrypted account/proxy secrets.
ENCRYPTION_KEY=
LETPUB_COOKIE=
